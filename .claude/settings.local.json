{
  "permissions": {
    "allow": [
      "Bash(mkdir -p docs/patterns docs/system-design docs/cs-fundamentals)",
      "Bash(mv progress.md plan.md docs/)",
      "Bash(mv patterns/hashmap.md docs/patterns/)",
      "Bash(rmdir patterns:*)",
      "Bash(touch docs/cs-fundamentals/os.md docs/cs-fundamentals/dbms.md docs/cs-fundamentals/networks.md)",
      "Bash(npx tsx *)",
      "WebFetch(domain:beta.cruscible.com)",
      "Bash(git add *)",
      "Bash(git commit -m ' *)"
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "node -e \"let b='';process.stdin.on('data',d=>b+=d);process.stdin.on('end',()=>{try{const j=JSON.parse(b);process.stdout.write('ctx '+(j?.context_window?.used_percentage??0)+'% used')}catch(e){}})\""
  }
}
